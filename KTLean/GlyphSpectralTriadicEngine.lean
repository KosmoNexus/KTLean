#check GlyphSpectralTriadicEngine.recurrenceMode_cycle_is_frobenius
#check GlyphSpectralTriadicEngine.FramedClosureFamily
#check GlyphSpectralTriadicEngine.SeedFamily
#check GlyphSpectralTriadicEngine.lawOfWalk
#check GlyphSpectralTriadicEngine.seedOfWalk
#check GlyphSpectralTriadicEngine.firstCompletion
#check GlyphSpectralTriadicEngine.walk_has_unique_firstCompletion
#check GlyphSpectralTriadicEngine.advance
#check GlyphSpectralTriadicEngine.SeededEngine
#check GlyphSpectralTriadicEngine.engineOfWalk
#check GlyphSpectralTriadicEngine.orbit
#check GlyphSpectralTriadicEngine.orbit_successor_completion
#check GlyphSpectralTriadicEngine.orbit_has_unique_nextValue
#check GlyphSpectralTriadicEngine.Intertwines
#check GlyphSpectralTriadicEngine.map_advance
#check GlyphSpectralTriadicEngine.forced_glyph_recurrence_is_triadically_deterministic
